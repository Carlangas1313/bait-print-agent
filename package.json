{
  "name": "bait-print-agent",
  "version": "0.9.13",
  "private": true,
  "description": "Agente local que escucha la cola de impresión de bait-pos y manda comandas a impresoras térmicas vía ESC/POS (USB / LAN raw 9100 / Bluetooth COM). Modos: console, virtual, usb.",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:setup": "tsx src/index.ts setup",
    "start": "node dist/index.js",
    "start:console": "node dist/index.js --mode console",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.cjs --format=cjs --external:pino-pretty --external:printer --external:electron-printer",
    "package:win": "npm run build && npm run bundle && node scripts/package-win.js",
    "release": "npm run package:win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.1",
    "commander": "^12.1.0",
    "node-thermal-printer": "^4.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "author": "Carlos Olivares <carlos.xyme@gmail.com>",
  "license": "UNLICENSED"
}
