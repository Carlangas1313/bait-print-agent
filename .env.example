# bait-print-agent · env config
# Copiar a .env y completar con valores reales.

# Supabase del proyecto bait-pos
SUPABASE_URL=https://ladhxyybqvaevtbhelil.supabase.co

# SERVICE ROLE KEY del proyecto Supabase. Bypassa RLS.
# ⚠️ SOLO PARA DESARROLLO LOCAL. NO distribuir a clientes.
# Para producción usar JWT scoped via /agent_authenticate (Sprint 3).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# UUID de la fila en print_agents que identifica este agente.
# Generado al crear el agente desde Settings → Impresoras → Agentes en bait-pos.
BAIT_AGENT_ID=00000000-0000-0000-0000-000000000000

# UUIDs del scope: el agente solo procesa jobs de este restaurant y location.
BAIT_RESTAURANT_ID=00000000-0000-0000-0000-00000000aaaa
BAIT_LOCATION_ID=00000000-0000-0000-0000-00000000bbbb

# Modo del agente: 'console' (stdout) | 'usb' (Sprint 3, no disponible aún)
BAIT_AGENT_MODE=console

# Nivel de logging: trace | debug | info | warn | error
LOG_LEVEL=info

# Cada cuantos segundos hacer heartbeat a print_agents.last_seen_at
HEARTBEAT_INTERVAL_SECONDS=30
