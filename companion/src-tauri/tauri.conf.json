{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "bAIt Print Companion",
  "version": "0.9.16",
  "identifier": "cl.bait.print-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "bAIt Print Companion",
        "width": 380,
        "height": 540,
        "minWidth": 380,
        "minHeight": 540,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "visible": false,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "bAIt Print Companion"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Utility",
    "shortDescription": "Companion del agente de impresi�n bAIt",
    "longDescription": "Ventana flotante + tray icon que se conecta al servicio bait-print-agent corriendo como servicio Windows. Muestra estado de impresoras, cola de jobs y permite tests de impresi�n sin abrir el dashboard."
  },
  "plugins": {}
}
